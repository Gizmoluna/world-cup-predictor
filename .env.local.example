# ===========================================================================
# World Cup Predictor — environment
# Copy to .env.local. The app runs fully WITHOUT any of these (demo mode with
# sample fixtures + in-memory data). Set them for real cross-device play.
# ===========================================================================

# --- Auth / sessions --------------------------------------------------------
# REQUIRED in production. Signs the login cookie so sessions can't be forged.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# --- Football data provider -------------------------------------------------
# manual (sample data) | api-football | sportmonks | statorium | worldcupapi
FOOTBALL_PROVIDER=api-football

# API-Football (api-sports.io). Used when FOOTBALL_PROVIDER=api-football.
# Free tier ~100 req/day; the app caches for 60s. Falls back to sample data
# until a key is set.
API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE=1      # World Cup = 1
API_FOOTBALL_SEASON=2026

# --- Supabase (database — persistence + cross-device) -----------------------
# NOTE: we use Supabase only as the DATABASE. Auth is handled in-app via
# name + PIN/password, so you do NOT need to configure Supabase Auth providers.
# Just run supabase/schema.sql + supabase/seed.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / sync protection -------------------------------------------------
# If set, /api/sync/* and /api/score require Authorization: Bearer <secret>.
# Vercel Cron sends this automatically when CRON_SECRET is set in the project.
CRON_SECRET=

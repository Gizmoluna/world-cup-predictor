# ===========================================================================
# Carina vs Johnny: World Cup Clash — environment
# Copy to .env.local. The app runs fully WITHOUT any of these (demo mode with
# seed fixtures + in-memory predictions). Set them for real cross-device play.
# ===========================================================================

# --- Football data provider -------------------------------------------------
# manual (default, seed data) | api-football | sportmonks | statorium | worldcupapi
FOOTBALL_PROVIDER=manual

# API-Football (api-sports.io). Only used when FOOTBALL_PROVIDER=api-football.
API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE=1      # World Cup = 1
API_FOOTBALL_SEASON=2026

# --- Supabase (persistence + cross-device) ----------------------------------
# Without these the app uses an in-memory demo store (single device only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / sync protection -------------------------------------------------
# If set, /api/sync/* and /api/score require  Authorization: Bearer <secret>
# (or ?key=<secret>). Leave empty for open local triggering.
CRON_SECRET=
